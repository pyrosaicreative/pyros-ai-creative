---
import '@fontsource-variable/inter';
---

<style is:inline>
  :root {
    /* Fonts */

    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    /* Brand Colors */

    --aw-color-primary: #8f1d1d;
    --aw-color-secondary: #6f1616;
    --aw-color-accent: #b32626;

    /* Text */

    --aw-color-text-heading: #ffffff;
    --aw-color-text-default: #e5ecf6;
    --aw-color-text-muted: rgb(229 236 246 / 66%);

    /* Background */

    --aw-color-bg-page: #090909;
    --aw-color-bg-page-dark: #090909;

    ::selection {
      background: #8f1d1d;
      color: white;
    }
  }

  .dark {
    /* Fonts */

    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    /* Brand Colors */

    --aw-color-primary: #8f1d1d;
    --aw-color-secondary: #6f1616;
    --aw-color-accent: #b32626;

    /* Text */

    --aw-color-text-heading: #ffffff;
    --aw-color-text-default: #e5ecf6;
    --aw-color-text-muted: rgb(229 236 246 / 66%);

    /* Background */

    --aw-color-bg-page: #090909;
    --aw-color-bg-page-dark: #090909;

    ::selection {
      background: #8f1d1d;
      color: white;
    }
  }
</style>