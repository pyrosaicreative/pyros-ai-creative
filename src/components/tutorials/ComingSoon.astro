<section class="bg-[#090909] py-20">

  <div class="mx-auto max-w-6xl px-6">

    <!-- Newsletter -->

    <div class="mx-auto max-w-3xl text-center">

      <h2 class="text-4xl font-bold text-white">
        Join the Newsletter
      </h2>

      <p class="mt-6 text-lg leading-8 text-gray-300">
        Get practical AI filmmaking tutorials, professional workflows and
        exclusive resources to help you create cinematic stories with AI.
      </p>

      <form
  id="newsletter-form"
  class="mt-10 flex flex-col gap-4 sm:flex-row"
>

  <input
    id="newsletter-email"
    type="email"
    placeholder="Enter your email"
    required
    class="flex-1 rounded-xl border border-[#B32626] bg-white px-6 py-4 text-black placeholder:text-gray-500 focus:outline-none focus:ring-2 focus:ring-[#B32626]"
  />

  <button
    id="newsletter-button"
    type="submit"
    class="rounded-xl bg-[#B32626] px-8 py-4 font-semibold text-white transition duration-300 hover:bg-[#991B1B]"
  >
    Join for Free
  </button>

</form>

<p
  id="newsletter-message"
  class="mt-4 text-center text-sm text-gray-300"
></p>

<script>
const form = document.getElementById("newsletter-form");
const email = document.getElementById("newsletter-email");
const button = document.getElementById("newsletter-button");
const message = document.getElementById("newsletter-message");

form.addEventListener("submit", async (e) => {
  e.preventDefault();

  button.disabled = true;
  button.textContent = "Joining...";
  message.textContent = "";

  try {
    const response = await fetch("/api/newsletter", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
      },
      body: JSON.stringify({
        email: email.value,
      }),
    });

    const text = await response.text();

    console.log("Response:", text);

    let data = {};

    try {
      data = JSON.parse(text);
    } catch {
      data = { message: text };
    }

    if (response.ok && data.success) {
      message.textContent = "Thanks! You're on the list.";
      email.value = "";
    } else {
      console.error(data);
      message.textContent =
        data.message || "Something went wrong.";
    }
  } catch (err) {
    console.error(err);
    message.textContent =
      "Unable to subscribe. Please try again.";
  }

  button.disabled = false;
  button.textContent = "Join for Free";
});
</script>

    </div>

    <!-- Coming Soon Image -->

    <div class="mt-20 overflow-hidden rounded-3xl border border-white/10 bg-[#111111] shadow-2xl">

      <img
        src="/images/tutorials/coming-soon.jpeg"
        alt="AI Filmmaking Tutorials Coming Soon"
        class="w-full object-cover"
      />

    </div>

    <!-- Description -->

    <div class="mx-auto mt-12 max-w-3xl text-center">

      <h2 class="text-4xl font-bold text-white">
        Tutorials are currently in production
      </h2>

      <p class="mt-6 text-lg leading-8 text-gray-300">
        We're creating practical AI filmmaking tutorials, complete production
        workflows and professional techniques designed to help you create
        cinematic AI content from idea to final film.
      </p>

    </div>

  </div>

</section>