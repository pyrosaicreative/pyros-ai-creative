---
import Section from './Section.astro';
import SectionHeader from './SectionHeader.astro';
---

<Section>

  <SectionHeader
    eyebrow="Phase 5"
    title="Production Ready"
    description="Your character is now production-ready."
    maxWidth="lg"
  />

  <div class="mt-8 max-w-3xl">

    <p class="text-sm leading-7 text-gray-300">
      You now have a complete Character Reference Pack that can be reused across future AI image and video generations while maintaining maximum visual consistency.
    </p>

    <p class="mt-6 text-sm leading-7 text-gray-300">
      Simply attach your Face Reference Sheet or Character Reference Sheet whenever you want to generate realistic images of your character in any situation.
    </p>

  </div>

</Section>