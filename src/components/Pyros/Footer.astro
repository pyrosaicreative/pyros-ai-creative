---
import { Icon } from 'astro-icon/components';
---

<footer class="relative mt-32 border-t border-white/5 bg-[#090909]">

  <!-- Top Accent -->
  <div class="h-px w-full bg-gradient-to-r from-transparent via-[#b32626]/30 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-8 py-24">

    <div class="grid gap-20 lg:grid-cols-[1.8fr_1fr_1fr]">

      <!-- Brand -->

      <div>

        <h2 class="text-4xl font-bold leading-tight tracking-tight text-white">
          The Future of<br />
          Filmmaking Starts Here.
        </h2>

        <p class="mt-8 max-w-md text-base leading-9 text-gray-400">
          Learn how to create cinematic videos, consistent AI characters,
          commercials and short movies using today's most powerful AI tools.
        </p>

      </div>

      <!-- Navigation -->

      <div>

        <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-white/70">
          Navigation
        </h3>

        <ul class="mt-8 space-y-5">

          <li>
            <a href="/" class="text-gray-400 transition duration-300 hover:text-white">
              Home
            </a>
          </li>

          <li>
            <a href="/about" class="text-gray-400 transition duration-300 hover:text-white">
              About
            </a>
          </li>
          <li>
  <a href="/why-ai-filmmaking" class="text-gray-400 transition duration-300 hover:text-white">
    Why AI Filmmaking
  </a>
</li>

          <li>
            <a href="/tutorials" class="text-gray-400 transition duration-300 hover:text-white">
              Tutorials
            </a>
          </li>

          <li>
            <a href="/prompt-packs" class="text-gray-400 transition duration-300 hover:text-white">
              Prompt Packs
            </a>
          </li>

        </ul>

      </div>

      <!-- Follow -->

      <div>

        <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-white/70">
          Follow
        </h3>

        <ul class="mt-8 space-y-5">

          <li>
            <a
              href="https://www.youtube.com/channel/UC52jL2fl7QQh37vjbau2XIg"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 text-gray-400 transition duration-300 hover:text-[#b32626]"
            >
              <Icon name="tabler:brand-youtube" class="h-5 w-5" />
              <span>YouTube</span>
            </a>
          </li>

          <li>
            <a
              href="https://www.tiktok.com/@pyrosaicreative"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 text-gray-400 transition duration-300 hover:text-[#b32626]"
            >
              <Icon name="tabler:brand-tiktok" class="h-5 w-5" />
              <span>TikTok</span>
            </a>
          </li>

          <li>
            <a
              href="https://www.linkedin.com/in/pyrosaicreative"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 text-gray-400 transition duration-300 hover:text-[#b32626]"
            >
              <Icon name="tabler:brand-linkedin" class="h-5 w-5" />
              <span>LinkedIn</span>
            </a>
          </li>

          <li>
            <a
              href="https://x.com/PyrosAICreative"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-3 text-gray-400 transition duration-300 hover:text-[#b32626]"
            >
              <Icon name="tabler:brand-x" class="h-5 w-5" />
              <span>X</span>
            </a>
          </li>

        </ul>

      </div>

    </div>

    <!-- Bottom -->

    <div class="mt-24 flex flex-col items-center justify-between gap-3 border-t border-white/5 pt-8 md:flex-row">

      <p class="text-sm text-gray-500">
        © 2026 PYROS AI Creative. All rights reserved.
      </p>

      <p class="text-sm text-gray-600">
        Learn AI Filmmaking. Build AI Stories.
      </p>

    </div>

  </div>

</footer>