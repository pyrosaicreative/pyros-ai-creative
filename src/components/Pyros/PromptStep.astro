---
import Section from './Section.astro';
import SectionHeader from './SectionHeader.astro';
import PromptBox from './PromptBox.astro';

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  goal: string;
  howToUse: string[];
  promptTitle: string;
  prompt: string;
}

const {
  eyebrow,
  title,
  description,
  goal,
  howToUse,
  promptTitle,
  prompt,
} = Astro.props;
---

<Section>

  <SectionHeader
    eyebrow={eyebrow}
    title={title}
    description={description}
    maxWidth="lg"
  />

  <div class="mt-10 max-w-3xl">

    <!-- Goal -->

    <h3 class="text-2xl font-bold text-white">
      Goal
    </h3>

    <p class="mt-4 text-base leading-relaxed text-gray-300">
      {goal}
    </p>

    <!-- How to Use -->

    <h3 class="mt-10 text-2xl font-bold text-white">
      How to Use
    </h3>

    <ol class="mt-4 space-y-1 text-sm leading-6 text-gray-300">

      {howToUse.map((step, index) => (
        <li>
          <strong class="text-white">{index + 1}.</strong> {step}
        </li>
      ))}

    </ol>

    <!-- Prompt -->

    <PromptBox
      title={promptTitle}
      prompt={prompt}
    />

  </div>

</Section>